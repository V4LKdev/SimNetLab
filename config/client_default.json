{
  "headless": false,
  "transport": {
    "backend": "enet",
    "host": "127.0.0.1",
    "local_ipc_path": "/tmp/simnet_transport.sock",
    "port": 7777,
    "max_clients": 8,
    "max_payload_bytes": 1200,
    "send_size_policy": "enforce_limit",
    "snapshot_delivery": "reliable_sequenced"
  },
  "render": {
    "enabled": true,
    "width": 1280,
    "height": 720
  },
  "telemetry": {
    "tracy_enabled": false,
    "console_log_enabled": true,
    "file_log_enabled": true,
    "log_directory": "logs",
    "min_level": "info",
    "metrics_csv_enabled": true,
    "metrics_json_enabled": false
  }
}
