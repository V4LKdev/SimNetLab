{
  "headless": true,
  "transport": {
    "host": "127.0.0.1",
    "port": 7777,
    "max_clients": 8
  },
  "telemetry": {
    "enable_tracy": false,
    "enable_file_log": true,
    "log_directory": "logs"
  },
  "benchmark": {
    "enabled": false,
    "repetitions": 10,
    "load_ramp": {
      "enabled": false,
      "add_boids_per_step": 500,
      "step_interval_seconds": 30.0,
      "max_boids": 1000000
    }
  }
}
