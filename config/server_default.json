{
  "headless": true,
  "transport": {
    "host": "127.0.0.1",
    "port": 7777,
    "max_clients": 8
  },
  "telemetry": {
    "tracy_enabled": false,
    "console_log_enabled": true,
    "file_log_enabled": true,
    "log_directory": "logs",
    "min_level": "info",
    "metrics_csv_enabled": true,
    "metrics_json_enabled": false
  },
  "benchmark": {
    "enabled": false,
    "repetitions": 10,
    "load_ramp": {
      "enabled": false,
      "add_boids_per_step": 500,
      "step_interval_seconds": 30.0,
      "max_boids": 1000000
    }
  }
}
